VITE_CLERK_PUBLISHABLE_KEY=

# ================================
# Database — Supabase
# ================================
# Runtime (Supavisor pooler — port 6543)
DATABASE_URL=
# Migrations only (direct — port 5432)
DATABASE_URL_DIRECT=

# ================================
# LLM Providers
# ================================
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY="not in used"
ZHIPU_API_KEY="optional"

# Multi-Agent Configuration
AGENT_EXTRACTOR_MODEL=models/gemini-3.1-flash-lite-preview
AGENT_STRATEGIST_MODEL=models/gemini-3.1-flash-lite-preview
AGENT_STRATEGIST_PROVIDER=gemini
AGENT_CRITIC_MODEL=llama-3.3-70b-versatile
AGENT_CRITIC_PROVIDER=groq

MODEL_NAME=models/gemini-3.1-flash-lite-preview

# ================================
# Embeddings & RAG
# ================================
EMBEDDING_PROVIDER=huggingface    # 'gemini', 'openai', or 'huggingface'
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
HUGGINGFACE_API_KEY="not needed"

# ================================
# Upstash Redis (Session & Rate Limiting)
# ================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SESSION_TTL_SECONDS=1800
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SECONDS=60

# ================================
# Clerk Authentication
# ================================
# Get from: Clerk Dashboard → API Keys → Secret keys
# CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=

# ================================
# Supabase Configuration
# ================================
USE_SUPABASE=true
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=