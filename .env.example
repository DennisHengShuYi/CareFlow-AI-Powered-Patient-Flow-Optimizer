VITE_CLERK_PUBLISHABLE_KEY=

# ================================
# Database — Supabase
# ================================
# Runtime (Supavisor pooler — port 6543)
DATABASE_URL=
# Migrations only (direct — port 5432)
DATABASE_URL_DIRECT=

# ================================
# LLM Provider
# ================================
LLM_PROVIDER=gemini          # switch to 'zhipu' with zero code changes
GEMINI_API_KEY=
# ZHIPU_API_KEY=            # Add your ZhipuAI key here if switching LLM_PROVIDER to 'zhipu'
MODEL_NAME=gemini-2.5-flash-lite    # or glm-4-plus for zhipu
EMBEDDING_DIMENSIONS=1536    # 1536 for Gemini, 768 for ZhipuAI

# ================================
# Upstash Redis (NOT redis-py — REST only)
# ================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SESSION_TTL_SECONDS=1800
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SECONDS=60

# ================================
# Clerk Authentication
# ================================
# Get from: Clerk Dashboard → API Keys → Secret keys
# CLERK_SECRET_KEY=sk_test_...    # Add your real Clerk secret key here
CLERK_JWKS_URL=

# ================================
# Supabase REST
# ================================
USE_SUPABASE=true

# Frontend + Backend Shared 
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend ONLY (never use a VITE_ prefix on this!)
SUPABASE_SERVICE_ROLE_KEY=